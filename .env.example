# ─────────────────────────────────────────────────────────────────────────────
# Institution Management Starter Kit — Environment Variables
#
# Copy this file to .env and fill in the values before starting the server.
# The application will exit with a descriptive error if any required variable
# is missing or invalid (validated via Zod in src/config/env.ts).
# ─────────────────────────────────────────────────────────────────────────────


# ─── Server ──────────────────────────────────────────────────────────────────

# Port the HTTP server listens on.
PORT=3000

# Runtime environment. Accepted values: development | production | test
NODE_ENV=development

# URL of the front-end client (used for CORS and email links, e.g. reset-password URL).
CLIENT_URL=http://localhost:5173


# ─── Database ────────────────────────────────────────────────────────────────

# Full PostgreSQL connection string consumed by Prisma.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/institution_db?schema=public

# (Docker Compose only) Individual credentials used to initialise the postgres service.
# These are NOT read by the application directly — DATABASE_URL above takes precedence.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=institution_db


# ─── JWT Authentication ───────────────────────────────────────────────────────

# Secret key used to sign and verify JSON Web Tokens.
# Use a long, random string in production (e.g. openssl rand -hex 64).
JWT_SECRET=change_me_to_a_long_random_secret_string

# Lifetime of the short-lived Access Token (e.g. 15m, 1h).
JWT_ACCESS_EXPIRY=15m

# Lifetime of the long-lived Refresh Token (e.g. 7d, 30d).
JWT_REFRESH_EXPIRY=7d


# ─── Brevo Email Service ──────────────────────────────────────────────────────

# API key obtained from your Brevo account dashboard.
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# The "From" email address for all outbound transactional emails.
# Must be a verified sender in your Brevo account.
BREVO_SENDER_EMAIL=noreply@yourdomain.com

# The display name shown in the "From" field of outbound emails.
BREVO_SENDER_NAME=Institution Management


# ─── Swagger / API Documentation ─────────────────────────────────────────────

# Set to "true" to disable the Swagger UI at /api-docs.
# Useful when deploying to production environments where you want to hide docs.
# Leave unset or set to "false" to keep Swagger enabled (default behaviour).
# DISABLE_SWAGGER=false

# Shared database defaults
POSTGRES_USER=postgres
POSTGRES_PASSWORD=mukabareke
POSTGRES_DB=institution_db

# Global runtime defaults
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CLIENT_URL=http://localhost:5173
BREVO_API_KEY=replace-with-brevo-key
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME=Institution Starter Kit

# Auth service
AUTH_SERVICE_URL=http://auth-service:3001

# User service
USER_SERVICE_URL=http://user-service:3002

# Role service
ROLE_SERVICE_URL=http://role-service:3003

# Department service
DEPARTMENT_SERVICE_URL=http://department-service:3004

# Resource service
RESOURCE_SERVICE_URL=http://resource-service:3005

# Transaction service
TRANSACTION_SERVICE_URL=http://transaction-service:3006

# Notification service
NOTIFICATION_SERVICE_URL=http://notification-service:3007

# Report service
REPORT_SERVICE_URL=http://report-service:3008

# Dashboard service
DASHBOARD_SERVICE_URL=http://dashboard-service:3009

# API documentation (Swagger UI at http://localhost:3000/api-docs)
PUBLIC_GATEWAY_URL=http://localhost:3000
DISABLE_SWAGGER=false

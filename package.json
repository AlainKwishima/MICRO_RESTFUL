{
  "name": "institution-management-starter-kit",
  "version": "1.0.0",
  "description": "A production-ready REST API backend scaffold for institution management systems",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "jest --coverage",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "ts-node src/database/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@getbrevo/brevo": "4.0.1",
    "@prisma/client": "6.6.0",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "express": "4.21.2",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.9",
    "@types/node": "20.17.30",
    "@types/supertest": "6.0.2",
    "@types/swagger-jsdoc": "6.0.4",
    "@types/swagger-ui-express": "4.1.8",
    "@typescript-eslint/eslint-plugin": "8.29.1",
    "@typescript-eslint/parser": "8.29.1",
    "eslint": "9.23.0",
    "fast-check": "3.23.2",
    "jest": "29.7.0",
    "nodemon": "3.1.9",
    "prettier": "3.5.3",
    "prisma": "6.6.0",
    "supertest": "7.1.0",
    "ts-jest": "29.3.1",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  }
}

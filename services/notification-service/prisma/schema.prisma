generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["notifications"]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  subject   String
  body      String
  status    String   @default("pending")
  sentAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("notifications")
}


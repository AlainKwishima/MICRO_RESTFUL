generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["resources"]
}

model Resource {
  id           String   @id
  name         String
  description  String?
  departmentId String
  status       String
  quantity     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@schema("resources")
}

